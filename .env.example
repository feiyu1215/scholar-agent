# ScholarAgent — LLM Configuration
# Copy this file to .env and fill in your API key.

# API Key (required)
# Works with OpenAI, or any OpenAI-compatible endpoint (e.g., Together, Groq, Ollama)
OPENAI_API_KEY=your-api-key-here

# Base URL (optional, default: https://api.openai.com/v1)
# Override for alternative providers:
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_BASE_URL=http://localhost:11434/v1  # Ollama

# Model (optional, default: gpt-4.1-mini)
# LLM_MODEL=gpt-4.1-mini
# LLM_MODEL=gpt-4o
# LLM_MODEL=claude-3-5-sonnet-20241022
