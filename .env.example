# ScholarAgent — Environment Configuration
# Copy this file to .env and fill in your values.

# ============================================================
# API Configuration (Required)
# ============================================================

# API Key — works with OpenAI or any OpenAI-compatible endpoint
OPENAI_API_KEY=your-api-key-here

# Base URL (optional, default: https://api.openai.com/v1)
# Examples for alternative providers:
# OPENAI_BASE_URL=https://api.together.xyz/v1       # Together AI
# OPENAI_BASE_URL=https://api.groq.com/openai/v1    # Groq
# OPENAI_BASE_URL=http://localhost:11434/v1          # Ollama
# OPENAI_BASE_URL=http://localhost:8000/v1           # vLLM

# ============================================================
# Model Configuration (Optional)
# ============================================================

# Primary model (default: gpt-4.1-mini)
# LLM_MODEL=gpt-4.1

# Multi-tier model routing:
# LLM_MODEL_HIGH=gpt-4.1          # Deep reasoning (hypothesis, complex analysis)
# LLM_MODEL_MEDIUM=gpt-4.1-mini   # Structured tasks (consolidation, routing)
# LLM_MODEL_LOW=gpt-4.1-mini      # Simple extraction (section parsing)

# ============================================================
# Feature Flags (Optional — all default ON except noted)
# ============================================================

# Uncomment to disable specific subsystems:
# SCHOLAR_GODEL_TABLE_PROCESSING=0      # Table validation engine
# SCHOLAR_GODEL_DUAL_LOOP=0             # Dual-loop orchestration
# SCHOLAR_GODEL_ADVERSARIAL_TRAINING=0  # Adversarial self-training
# SCHOLAR_GODEL_FIGURE_SEMANTIC=0       # Figure semantic analysis
# SCHOLAR_GODEL_DEEP_REFLECT=0          # Deep reflection (LLM-powered)

# Uncomment to enable (default OFF):
# SCHOLAR_GODEL_STREAMING=1             # Streaming output
