                "default": "priority"
              },
              "include_stats": {
                "type": "boolean",
                "description": "Whether to include session statistics.",
                "default": true
              }
            },
            "required": []
          },
          "handler": "skill_handlers/structured_export.py::handle_export_review"
        }
